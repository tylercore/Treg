{
  "name": "@tylercore/treg",
  "version": "1.0.9",
  "description": "Treg is a CLI tool that injects an engineering immune system into existing projects.",
  "keywords": [
    "treg",
    "cli",
    "tooling",
    "infrastructure",
    "project-setup",
    "code-quality",
    "lint",
    "formatting",
    "typescript",
    "testing",
    "ai-rules"
  ],
  "author": "tylercore <ty.ho1126@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/tylercore/treg#readme",
  "bugs": {
    "url": "https://github.com/tylercore/treg/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tylercore/treg.git"
  },
  "bin": {
    "treg": "dist/init-project.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type:check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/write-dist-package-json.mjs",
    "release": "node scripts/release.mjs",
    "prepare": "husky",
    "prepublishOnly": "pnpm format:check && pnpm lint:check && pnpm type:check && pnpm test && pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "mrm-core": "^7.1.22"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.0",
    "typescript": "^5"
  }
}
